# ── Server ───────────────────────────────────────────────────────────────────
PORT=8001
NODE_ENV=production

# ── Database ─────────────────────────────────────────────────────────────────
# Local development (no SSL):
DATABASE_URL=postgresql://postgres@localhost:5432/webenablix
# Supabase / Render Postgres / Neon (SSL required):
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_64_chars_min

# ── Admin Panel ───────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_strong_password

# ── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ── CORS ─────────────────────────────────────────────────────────────────────
# Set to your deployed Vercel URL once known
FRONTEND_URL=https://your-app.vercel.app
