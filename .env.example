# ═══════════════════════════════════════════════════════════════════════════
# Docker Compose Environment Variables
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values
# These variables are used by docker-compose.yml
# ═══════════════════════════════════════════════════════════════════════════

# ── Google OAuth (Optional) ──────────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# ── Production Security (Change these for production!) ──────────────────────
# JWT_SECRET=your_production_secret_min_64_chars
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=strong_admin_password

# ── Database (Optional - defaults in docker-compose.yml) ────────────────────
# POSTGRES_DB=webenablix
# POSTGRES_USER=webenablix_user
# POSTGRES_PASSWORD=webenablix_pass
